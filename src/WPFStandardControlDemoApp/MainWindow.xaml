<Window
    x:Class="WPFStandardControlDemoApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:about="clr-namespace:WPFStandardControlDemoApp.Features.About"
    xmlns:button="clr-namespace:WPFStandardControlDemoApp.Features.ButtonUsage"
    xmlns:checkbox="clr-namespace:WPFStandardControlDemoApp.Features.CheckBoxUsage"
    xmlns:combobox="clr-namespace:WPFStandardControlDemoApp.Features.ComboBoxUsage"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:datepicker="clr-namespace:WPFStandardControlDemoApp.Features.DatePickerUsage"
    xmlns:dockpanel="clr-namespace:WPFStandardControlDemoApp.Features.DockPanelUsage"
    xmlns:expander="clr-namespace:WPFStandardControlDemoApp.Features.ExpanderUsage"
    xmlns:grid="clr-namespace:WPFStandardControlDemoApp.Features.GridUsage"
    xmlns:gridsplitter="clr-namespace:WPFStandardControlDemoApp.Features.GridSplitterUsage"
    xmlns:groupbox="clr-namespace:WPFStandardControlDemoApp.Features.GroupBoxUsage"
    xmlns:home="clr-namespace:WPFStandardControlDemoApp.Features.Home"
    xmlns:label="clr-namespace:WPFStandardControlDemoApp.Features.LabelUsage"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:passwordbox="clr-namespace:WPFStandardControlDemoApp.Features.PasswordBoxUsage"
    xmlns:progressbar="clr-namespace:WPFStandardControlDemoApp.Features.ProgressBarUsage"
    xmlns:radiobutton="clr-namespace:WPFStandardControlDemoApp.Features.RadioButtonUsage"
    xmlns:repeatbutton="clr-namespace:WPFStandardControlDemoApp.Features.RepeatButtonUsage"
    xmlns:scrollviewer="clr-namespace:WPFStandardControlDemoApp.Features.ScrollViewerUsage"
    xmlns:slider="clr-namespace:WPFStandardControlDemoApp.Features.SliderUsage"
    xmlns:stackpanel="clr-namespace:WPFStandardControlDemoApp.Features.StackPanelUsage"
    xmlns:tabcontrol="clr-namespace:WPFStandardControlDemoApp.Features.TabControlUsage"
    xmlns:tabitem="clr-namespace:WPFStandardControlDemoApp.Features.TabItemUsage"
    xmlns:textblock="clr-namespace:WPFStandardControlDemoApp.Features.TextBlockUsage"
    xmlns:textbox="clr-namespace:WPFStandardControlDemoApp.Features.TextBoxUsage"
    xmlns:togglebutton="clr-namespace:WPFStandardControlDemoApp.Features.ToggleButtonUsage"
    xmlns:uniformgrid="clr-namespace:WPFStandardControlDemoApp.Features.UniformGridUsage"
    xmlns:viewbox="clr-namespace:WPFStandardControlDemoApp.Features.ViewboxUsage"
    xmlns:wrappanel="clr-namespace:WPFStandardControlDemoApp.Features.WrapPanelUsage"
    Title="WPFStandardControlDemoApp"
    Width="1200"
    Height="800"
    mc:Ignorable="d">
    <Window.Resources>
        <home:HomeViewModel x:Key="HomeViewModel" />
        <textbox:TextBoxUsageViewModel x:Key="TextBoxUsageViewModel" />
        <button:ButtonUsageViewModel x:Key="ButtonUsageViewModel" />
        <togglebutton:ToggleButtonUsageViewModel x:Key="ToggleButtonUsageViewModel" />
        <checkbox:CheckBoxUsageViewModel x:Key="CheckBoxUsageViewModel" />
        <radiobutton:RadioButtonUsageViewModel x:Key="RadioButtonUsageViewModel" />
        <combobox:ComboBoxUsageViewModel x:Key="ComboBoxUsageViewModel" />
        <repeatbutton:RepeatButtonUsageViewModel x:Key="RepeatButtonUsageViewModel" />
        <textblock:TextBlockUsageViewModel x:Key="TextBlockUsageViewModel" />
        <label:LabelUsageViewModel x:Key="LabelUsageViewModel" />
        <grid:GridUsageViewModel x:Key="GridUsageViewModel" />
        <stackpanel:StackPanelUsageViewModel x:Key="StackPanelUsageViewModel" />
        <wrappanel:WrapPanelUsageViewModel x:Key="WrapPanelUsageViewModel" />
        <dockpanel:DockPanelUsageViewModel x:Key="DockPanelUsageViewModel" />
        <uniformgrid:UniformGridUsageViewModel x:Key="UniformGridUsageViewModel" />
        <gridsplitter:GridSplitterUsageViewModel x:Key="GridSplitterUsageViewModel" />
        <scrollviewer:ScrollViewerUsageViewModel x:Key="ScrollViewerUsageViewModel" />
        <groupbox:GroupBoxUsageViewModel x:Key="GroupBoxUsageViewModel" />
        <expander:ExpanderUsageViewModel x:Key="ExpanderUsageViewModel" />
        <tabcontrol:TabControlUsageViewModel x:Key="TabControlUsageViewModel" />
        <tabitem:TabItemUsageViewModel x:Key="TabItemUsageViewModel" />
        <viewbox:ViewboxUsageViewModel x:Key="ViewboxUsageViewModel" />
        <passwordbox:PasswordBoxUsageViewModel x:Key="PasswordBoxUsageViewModel" />
        <datepicker:DatePickerUsageViewModel x:Key="DatePickerUsageViewModel" />
        <slider:SliderUsageViewModel x:Key="SliderUsageViewModel" />
        <progressbar:ProgressBarUsageViewModel x:Key="ProgressBarUsageViewModel" />

    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border
            Grid.Column="1"
            BorderBrush="{Binding BorderBrush, ElementName=ContentsSelector}"
            BorderThickness="1">
            <Border.Resources>
                <DataTemplate DataType="{x:Type home:HomeViewModel}">
                    <home:HomeControl DataContext="{StaticResource HomeViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type textbox:TextBoxUsageViewModel}">
                    <textbox:TextBoxUsageControl DataContext="{StaticResource TextBoxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type button:ButtonUsageViewModel}">
                    <button:ButtonUsageControl DataContext="{StaticResource ButtonUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type togglebutton:ToggleButtonUsageViewModel}">
                    <togglebutton:ToggleButtonUsageControl DataContext="{StaticResource ToggleButtonUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type checkbox:CheckBoxUsageViewModel}">
                    <checkbox:CheckBoxUsageControl DataContext="{StaticResource CheckBoxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type radiobutton:RadioButtonUsageViewModel}">
                    <radiobutton:RadioButtonUsageControl DataContext="{StaticResource RadioButtonUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type combobox:ComboBoxUsageViewModel}">
                    <combobox:ComboBoxUsageControl DataContext="{StaticResource ComboBoxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type repeatbutton:RepeatButtonUsageViewModel}">
                    <repeatbutton:RepeatButtonUsageControl DataContext="{StaticResource RepeatButtonUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type textblock:TextBlockUsageViewModel}">
                    <textblock:TextBlockUsageControl DataContext="{StaticResource TextBlockUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type label:LabelUsageViewModel}">
                    <label:LabelUsageControl DataContext="{StaticResource LabelUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type grid:GridUsageViewModel}">
                    <grid:GridUsageControl DataContext="{StaticResource GridUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type stackpanel:StackPanelUsageViewModel}">
                    <stackpanel:StackPanelUsageControl DataContext="{StaticResource StackPanelUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type wrappanel:WrapPanelUsageViewModel}">
                    <wrappanel:WrapPanelUsageControl DataContext="{StaticResource WrapPanelUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type dockpanel:DockPanelUsageViewModel}">
                    <dockpanel:DockPanelUsageControl DataContext="{StaticResource DockPanelUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type uniformgrid:UniformGridUsageViewModel}">
                    <uniformgrid:UniformGridUsageControl DataContext="{StaticResource UniformGridUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type gridsplitter:GridSplitterUsageViewModel}">
                    <gridsplitter:GridSplitterUsageControl DataContext="{StaticResource GridSplitterUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type scrollviewer:ScrollViewerUsageViewModel}">
                    <scrollviewer:ScrollViewerUsageControl DataContext="{StaticResource ScrollViewerUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type groupbox:GroupBoxUsageViewModel}">
                    <groupbox:GroupBoxUsageControl DataContext="{StaticResource GroupBoxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type expander:ExpanderUsageViewModel}">
                    <expander:ExpanderUsageControl DataContext="{StaticResource ExpanderUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type tabcontrol:TabControlUsageViewModel}">
                    <tabcontrol:TabControlUsageControl DataContext="{StaticResource TabControlUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type tabitem:TabItemUsageViewModel}">
                    <tabitem:TabItemUsageControl DataContext="{StaticResource TabItemUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type viewbox:ViewboxUsageViewModel}">
                    <viewbox:ViewboxUsageControl DataContext="{StaticResource ViewboxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type passwordbox:PasswordBoxUsageViewModel}">
                    <passwordbox:PasswordBoxUsageControl DataContext="{StaticResource PasswordBoxUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type datepicker:DatePickerUsageViewModel}">
                    <datepicker:DatePickerUsageControl DataContext="{StaticResource DatePickerUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type slider:SliderUsageViewModel}">
                    <slider:SliderUsageControl DataContext="{StaticResource SliderUsageViewModel}" />
                </DataTemplate>
                <DataTemplate DataType="{x:Type progressbar:ProgressBarUsageViewModel}">
                    <progressbar:ProgressBarUsageControl DataContext="{StaticResource ProgressBarUsageViewModel}" />
                </DataTemplate>

            </Border.Resources>
            <ContentControl Content="{Binding SelectedItem.Content, ElementName=ContentsSelector}" />
        </Border>
        <Grid Grid.Column="0">
            <ListBox x:Name="ContentsSelector" SelectionMode="Single">
                <ListBox.Resources>
                    <Style BasedOn="{StaticResource ContentsListItem}" TargetType="ListBoxItem" />
                </ListBox.Resources>
                <ListBoxItem Content="{StaticResource HomeViewModel}" IsSelected="True" />
                <ListBoxItem Content="{StaticResource TextBoxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ButtonUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ToggleButtonUsageViewModel}" />
                <ListBoxItem Content="{StaticResource CheckBoxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource RadioButtonUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ComboBoxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource RepeatButtonUsageViewModel}" />
                <ListBoxItem Content="{StaticResource TextBlockUsageViewModel}" />
                <ListBoxItem Content="{StaticResource LabelUsageViewModel}" />
                <ListBoxItem Content="{StaticResource GridUsageViewModel}" />
                <ListBoxItem Content="{StaticResource StackPanelUsageViewModel}" />
                <ListBoxItem Content="{StaticResource WrapPanelUsageViewModel}" />
                <ListBoxItem Content="{StaticResource DockPanelUsageViewModel}" />
                <ListBoxItem Content="{StaticResource UniformGridUsageViewModel}" />
                <ListBoxItem Content="{StaticResource GridSplitterUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ScrollViewerUsageViewModel}" />
                <ListBoxItem Content="{StaticResource GroupBoxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ExpanderUsageViewModel}" />
                <ListBoxItem Content="{StaticResource TabControlUsageViewModel}" />
                <ListBoxItem Content="{StaticResource TabItemUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ViewboxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource PasswordBoxUsageViewModel}" />
                <ListBoxItem Content="{StaticResource DatePickerUsageViewModel}" />
                <ListBoxItem Content="{StaticResource SliderUsageViewModel}" />
                <ListBoxItem Content="{StaticResource ProgressBarUsageViewModel}" />

            </ListBox>
        </Grid>
    </Grid>
</Window>
