<Application
    x:Class="WPFStandardControlDemoApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp"
    Startup="Application_Startup"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/ExpanderStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/ListBoxItemStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/TextBlockStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/GroupBoxStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/BorderStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/ToggleButtonStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/TextBoxStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/SliderStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/RichTextBoxStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>