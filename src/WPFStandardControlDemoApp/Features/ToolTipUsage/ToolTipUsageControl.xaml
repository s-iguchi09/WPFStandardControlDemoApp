                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                            <Slider
                                x:Name="ValueBorderThicknessSlider"
                                Maximum="20"
                                Minimum="0"
                                Style="{StaticResource PropertySliderStyle}"
                                Value="2" />
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Button x:Name="BorderToolTipButton" Content="Show ToolTip on hover.">
                            <Button.ToolTip>
                                <ToolTip
                                    BorderBrush="{Binding Data.SelectedValue, Source={StaticResource BorderBrushProxy}}"
                                    BorderThickness="{Binding Data.Value, Source={StaticResource BorderThicknessProxy}}"
                                    Content="Border Settings Demo" />
                            </Button.ToolTip>
                        </Button>
                    </GroupBox>
                    <ToggleButton x:Name="BorderDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BorderDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=BorderDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="SelectedBorderBrushComboBox,ValueBorderThicknessSlider,BorderToolTipButton">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
