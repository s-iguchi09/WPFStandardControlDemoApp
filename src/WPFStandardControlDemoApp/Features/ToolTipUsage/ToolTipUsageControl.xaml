            <Expander Header="BorderBrush(Control)&#10;BorderThickness(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <StackPanel.Resources>
                        <helpers:BindingProxy x:Key="BorderBrushProxy" Data="{Binding Path=., ElementName=SelectedBorderBrushComboBox}" />
                        <helpers:BindingProxy x:Key="BorderThicknessProxy" Data="{Binding Path=., ElementName=ValueBorderThicknessSlider}" />
                    </StackPanel.Resources>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Columns="2">
                            <ComboBox
