<UserControl
    x:Class="WPFStandardControlDemoApp.Features.DockPanelUsage.DockPanelUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.DockPanelUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">

    <UserControl.Resources>
        <sys:String x:Key="rowXamlName">DockPanelUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="DockPanel" />

            <Expander Header="LastChildFill" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="LastChildFillCheckBox"
                            VerticalContentAlignment="Center"
                            Content="LastChildFill" />
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel x:Name="LastChildFillDockPanel" LastChildFill="{Binding IsChecked, ElementName=LastChildFillCheckBox}">
                            <Label
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Background="SkyBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                        </DockPanel>
                    </GroupBox>
                    <ToggleButton x:Name="LastChildFillDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=LastChildFillDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=LastChildFillDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="LastChildFillCheckBox,LastChildFillDockPanel">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Dock" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <ComboBox
                            x:Name="DockComboBox"
                            DisplayMemberPath="Name"
                            ItemsSource="{markupextensions:EnumBindingSource EnumType=Dock}"
                            SelectedIndex="0"
                            SelectedValuePath="Value" />
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel
                            x:Name="DockUsageDockPanel"
                            Height="100"
                            LastChildFill="False">
                            <Label
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1"
                                DockPanel.Dock="{Binding SelectedValue, ElementName=DockComboBox}" />
                        </DockPanel>
                    </GroupBox>
                    <ToggleButton x:Name="DockDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=DockDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=DockDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="DockComboBox,DockUsageDockPanel">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Background(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="BackgroundComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel
                            x:Name="BackgroundDockPanel"
                            Height="30"
                            Background="{Binding SelectedItem.Value, ElementName=BackgroundComboBox}" />
                    </GroupBox>
                    <ToggleButton x:Name="BackgroundDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BackgroundDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=BackgroundDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="BackgroundComboBox,BackgroundDockPanel">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="ZIndex(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <GroupBox Header="ZIndex(Item1)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem1Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="1" />
                                </GroupBox>
                                <GroupBox Header="ZIndex(Item2)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem2Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="2" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel x:Name="ZIndexDockPanel">
                            <Label
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem1Text}"
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Margin="-30,0,0,0"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem2Text}"
                                Background="SkyBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                        </DockPanel>
                    </GroupBox>
                    <ToggleButton x:Name="ZIndexDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ZIndexDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=ZIndexDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="ZIndexItem1Text,ZIndexItem2Text,ZIndexDockPanel">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>