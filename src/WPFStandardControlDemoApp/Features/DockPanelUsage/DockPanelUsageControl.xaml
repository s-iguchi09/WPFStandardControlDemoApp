<UserControl
    x:Class="WPFStandardControlDemoApp.Features.DockPanelUsage.DockPanelUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.DockPanelUsage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="DockPanel" />
            <Expander Header="LastChildFill" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="LastChildFillCheckBox"
                            VerticalContentAlignment="Center"
                            Content="LastChildFill" />
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel LastChildFill="{Binding IsChecked, ElementName=LastChildFillCheckBox}">
                            <Label
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Background="SkyBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                        </DockPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="Dock" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <ComboBox
                            x:Name="DockComboBox"
                            ItemsSource="{x:Static helpers:DockHelper.AllDocks}"
                            SelectedIndex="0" />
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel Height="100" LastChildFill="False">
                            <Label
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1"
                                DockPanel.Dock="{Binding SelectedValue, ElementName=DockComboBox}" />
                        </DockPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="Background(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="Background"
                                behaviors:SelectorInitialSelectionBehavior.InitialSelectedIndex="0"
                                DisplayMemberPath="Key"
                                ItemsSource="{x:Static helpers:BrushesHelper.AllBrushes}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel Height="30" Background="{Binding SelectedItem.Value, ElementName=Background}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="ZIndex(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <GroupBox Header="ZIndex(Item1)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem1Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="1" />
                                </GroupBox>
                                <GroupBox Header="ZIndex(Item2)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem2Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="2" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <DockPanel>
                            <Label
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem1Text}"
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Margin="-30,0,0,0"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem2Text}"
                                Background="SkyBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                        </DockPanel>
                    </GroupBox>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
