<UserControl
    x:Class="WPFStandardControlDemoApp.Features.TabItemUsage.TabItemUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.TabItemUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="2000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="CodeViewerTextBoxStyleCustom"
            BasedOn="{StaticResource CodeViewerTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="behaviors:XamlExtractBehavior.RawXamlFileName" Value="TabItemUsageControl.xaml.raw" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="TabItem" />
            <Expander Header="IsSelected" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="IsSelected" Style="{StaticResource SubGroupBox}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox
                                    x:Name="IsSelectedTab1"
                                    VerticalContentAlignment="Center"
                                    Content="Tab1" />
                                <CheckBox
                                    x:Name="IsSelectedTab2"
                                    VerticalContentAlignment="Center"
                                    Content="Tab2" />
                            </StackPanel>
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <TabControl x:Name="IsSelectedTabControl">
                            <TabItem
                                Content="Item1"
                                Header="Tab1"
                                IsSelected="{Binding IsChecked, ElementName=IsSelectedTab1}" />
                            <TabItem
                                Content="Item2"
                                Header="Tab2"
                                IsSelected="{Binding IsChecked, ElementName=IsSelectedTab2}" />
                        </TabControl>
                    </GroupBox>
                    <ToggleButton x:Name="IsSelectedPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsSelectedPopupButton}"
                        PlacementTarget="{Binding ElementName=IsSelectedPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="IsSelectedTab1,IsSelectedTab2,IsSelectedTabControl" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="TabStripPlacement" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="TabStripPlacement" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="TabStripPlacementComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=Dock}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <TabControl x:Name="TabStripPlacementTabControl" TabStripPlacement="{Binding SelectedValue, ElementName=TabStripPlacementComboBox}">
                        <TabItem
                            x:Name="TabItem1"
                            Content="Item1"
                            Header="Tab1" />
                        <TabItem
                            x:Name="TabItem2"
                            Content="Item2"
                            Header="Tab2" />
                    </TabControl>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <UniformGrid Rows="1">
                            <GroupBox Header="TabItem1" Style="{StaticResource SubGroupBox}">
                                <TextBlock x:Name="TabItem1TabStripPlacement" Text="{Binding TabStripPlacement, ElementName=TabItem1}" />
                            </GroupBox>
                            <GroupBox Header="TabItem2" Style="{StaticResource SubGroupBox}">
                                <TextBlock x:Name="TabItem2TabStripPlacement" Text="{Binding TabStripPlacement, ElementName=TabItem2}" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <ToggleButton x:Name="TabStripPlacementPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=TabStripPlacementPopupButton}"
                        PlacementTarget="{Binding ElementName=TabStripPlacementPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="TabStripPlacementTabControl,TabItem1TabStripPlacement,TabItem2TabStripPlacement" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
