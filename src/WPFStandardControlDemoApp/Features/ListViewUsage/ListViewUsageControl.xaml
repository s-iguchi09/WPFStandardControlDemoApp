<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ListViewUsage.ListViewUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="3000"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="RawXamlName">ListViewUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="ListView" />

            <Expander Header="SelectionMode" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="SelectionMode" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="SelectionModeComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=SelectionMode}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <ListView
                                x:Name="SelectionModeListView"
                                Height="100"
                                SelectionMode="{Binding SelectedValue, ElementName=SelectionModeComboBox}">
                                <ListViewItem Content="Item 1" />
                                <ListViewItem Content="Item 2" />
                                <ListViewItem Content="Item 3" />
                                <ListViewItem Content="Item 4" />
                            </ListView>
                            <GroupBox Header="SelectedItems.Count" Style="{StaticResource SubGroupBox}">
                                <TextBlock HorizontalAlignment="Center" Text="{Binding SelectedItems.Count, ElementName=SelectionModeListView}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="SelectionModeDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=SelectionModeDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=SelectionModeDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="SelectionModeComboBox,SelectionModeListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="View&#10;Columns(GridView)&#10;AllowsColumnReorder(GridView)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="AllowsColumnReorder" Style="{StaticResource SubGroupBox}">
                            <CheckBox
                                x:Name="AllowsColumnReorderCheckBox"
                                HorizontalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="AllowsColumnReorder"
                                IsChecked="True" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <ListView
                            x:Name="ViewColumnsListView"
                            Height="150"
                            ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}">
                            <ListView.View>
                                <GridView AllowsColumnReorder="{Binding IsChecked, ElementName=AllowsColumnReorderCheckBox}">
                                    <GridViewColumn
                                        Width="auto"
                                        DisplayMemberBinding="{Binding Name}"
                                        Header="Name" />
                                    <GridViewColumn
                                        Width="auto"
                                        DisplayMemberBinding="{Binding Value}"
                                        Header="Value" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                    <ToggleButton x:Name="ViewColumnsDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ViewColumnsDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=ViewColumnsDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="AllowsColumnReorderCheckBox,ViewColumnsListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Width(GridViewColumn)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Column Width" Style="{StaticResource SubGroupBox}">
                            <Slider
                                x:Name="WidthSlider"
                                AutoToolTipPlacement="TopLeft"
                                Maximum="300"
                                Minimum="50"
                                Value="150" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <ListView
                            x:Name="WidthListView"
                            Height="150"
                            ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        Width="auto"
                                        DisplayMemberBinding="{Binding Name}"
                                        Header="Name&#10;(Auto Width)" />
                                    <GridViewColumn
                                        Width="{Binding Value, ElementName=WidthSlider}"
                                        DisplayMemberBinding="{Binding Value}"
                                        Header="Value&#10;(Dynamic Width)" />
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </GroupBox>
                    <ToggleButton x:Name="WidthDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=WidthDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=WidthDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="WidthSlider,WidthListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="SelectedIndex(Selector)&#10;SelectedItem(Selector)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="SelectedIndex" Style="{StaticResource SubGroupBox}">
                            <TextBox
                                x:Name="SelectedIndexTextBox"
                                behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                Text="{Binding SelectedIndex, ElementName=SelectedIndexSelectedItemListView, UpdateSourceTrigger=PropertyChanged}" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <ListView
                                x:Name="SelectedIndexSelectedItemListView"
                                Height="100"
                                SelectedIndex="0">
                                <ListViewItem Content="Item A" />
                                <ListViewItem Content="Item B" />
                                <ListViewItem Content="Item C" />
                            </ListView>
                            <UniformGrid Columns="2">
                                <GroupBox Header="SelectedIndex" Style="{StaticResource SubGroupBox}">
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding SelectedIndex, ElementName=SelectedIndexSelectedItemListView}" />
                                </GroupBox>
                                <GroupBox Header="SelectedItem.Content" Style="{StaticResource SubGroupBox}">
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding SelectedItem.Content, ElementName=SelectedIndexSelectedItemListView, FallbackValue='null'}" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="SelectedIndexSelectedItemDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=SelectedIndexSelectedItemDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=SelectedIndexSelectedItemDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="SelectedIndexTextBox,SelectedIndexSelectedItemListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="IsSelected(ListBoxItem)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="IsSelected(Item 1)" Style="{StaticResource SubGroupBox}">
                            <CheckBox
                                x:Name="IsSelectedCheckBox"
                                HorizontalAlignment="Center"
                                VerticalContentAlignment="Center"
                                Content="IsSelected(Item 1)" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <ListView x:Name="IsSelectedListView" Height="100">
                                <ListViewItem Content="Item 1 (Controlled)" IsSelected="{Binding IsChecked, ElementName=IsSelectedCheckBox}" />
                                <ListViewItem Content="Item 2 (Manual)" />
                            </ListView>
                            <GroupBox Header="SelectedItems.Count" Style="{StaticResource SubGroupBox}">
                                <TextBlock HorizontalAlignment="Center" Text="{Binding SelectedItems.Count, ElementName=IsSelectedListView}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="IsSelectedDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsSelectedDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=IsSelectedDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsSelectedCheckBox,IsSelectedListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="HorizontalScrollBarVisibility(ScrollViewer)&#10;VerticalScrollBarVisibility(ScrollViewer)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Columns="2">
                            <GroupBox Header="HorizontalScrollBar" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="HorizontalScrollBarVisibilityComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=ScrollBarVisibility}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <GroupBox Header="VerticalScrollBar" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="VerticalScrollBarVisibilityComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=ScrollBarVisibility}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <ListView
                            x:Name="ScrollBarVisibilityListView"
                            Height="100"
                            ScrollViewer.HorizontalScrollBarVisibility="{Binding SelectedValue, ElementName=HorizontalScrollBarVisibilityComboBox}"
                            ScrollViewer.VerticalScrollBarVisibility="{Binding SelectedValue, ElementName=VerticalScrollBarVisibilityComboBox}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn
                                        Width="500"
                                        DisplayMemberBinding="{Binding}"
                                        Header="Very Long Column" />
                                </GridView>
                            </ListView.View>
                            <ListViewItem Content="Scroll Test Item 1" />
                            <ListViewItem Content="Scroll Test Item 2" />
                            <ListViewItem Content="Scroll Test Item 3" />
                            <ListViewItem Content="Scroll Test Item 4" />
                            <ListViewItem Content="Scroll Test Item 5" />
                        </ListView>
                    </GroupBox>
                    <ToggleButton x:Name="ScrollBarVisibilityDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ScrollBarVisibilityDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=ScrollBarVisibilityDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="HorizontalScrollBarVisibilityComboBox,VerticalScrollBarVisibilityComboBox,ScrollBarVisibilityListView">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>