<UserControl
    x:Class="WPFStandardControlDemoApp.Features.StackPanelUsage.StackPanelUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.StackPanelUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1000"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style
            x:Key="CodeViewerTextBoxStyleCustom"
            BasedOn="{StaticResource CodeViewerTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="behaviors:XamlExtractBehavior.RawXamlFileName" Value="StackPanelUsageControl.xaml.raw" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="StackPanel" />

            <Expander Header="Orientation" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Orientation" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="OrientationComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=Orientation}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel x:Name="OrientationStackPanel" Orientation="{Binding SelectedValue, ElementName=OrientationComboBox}">
                            <Label
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                            <Label
                                Margin="2"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item3" />
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="OrientationDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=OrientationDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=OrientationDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="OrientationComboBox,OrientationStackPanel" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Background(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="BackgroundComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel
                            x:Name="BackgroundStackPanel"
                            Height="30"
                            Background="{Binding SelectedItem.Value, ElementName=BackgroundComboBox}" />
                    </GroupBox>
                    <ToggleButton x:Name="BackgroundDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BackgroundDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=BackgroundDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="BackgroundComboBox,BackgroundStackPanel" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="ZIndex(Panel)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <GroupBox Header="ZIndex(Item1)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem1Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="1" />
                                </GroupBox>
                                <GroupBox Header="ZIndex(Item2)" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="ZIndexItem2Text"
                                        behaviors:TextBoxIntInputBehavior.IsEnabled="True"
                                        Text="2" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel x:Name="ZIndexStackPanel">
                            <Label
                                VerticalAlignment="Top"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem1Text}"
                                Background="LightBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                            <Label
                                Margin="0,-15,0,0"
                                VerticalAlignment="Top"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexItem2Text}"
                                Background="SkyBlue"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item2" />
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="ZIndexDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ZIndexDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=ZIndexDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="ZIndexItem1Text,ZIndexItem2Text,ZIndexStackPanel" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>