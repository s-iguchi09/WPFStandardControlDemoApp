<UserControl
    x:Class="WPFStandardControlDemoApp.Features.RadioButtonUsage.RadioButtonUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.RadioButtonUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="RadioButton" />
            <Expander Header="GroupName" Style="{StaticResource ContentsExpander}">
                <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                    <UniformGrid Rows="1">
                        <GroupBox Header="GroupName=(Null)" Style="{StaticResource SubGroupBox}">
                            <StackPanel>
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="A"
                                    IsChecked="True" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="B" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="C" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="D" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="E" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="F" />
                            </StackPanel>
                        </GroupBox>
                        <GroupBox Header="GroupName=1 or 2" Style="{StaticResource SubGroupBox}">
                            <StackPanel>
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="A(Group:1)"
                                    GroupName="1"
                                    IsChecked="True" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="B(Group:1)"
                                    GroupName="1" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="C(Group:1)"
                                    GroupName="1" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="D(Group:2)"
                                    GroupName="2"
                                    IsChecked="True" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="E(Group:2)"
                                    GroupName="2" />
                                <RadioButton
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="F(Group:2)"
                                    GroupName="2" />
                            </StackPanel>
                        </GroupBox>
                    </UniformGrid>
                </GroupBox>
            </Expander>
            <Expander Header="VerticalContentAlignment(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="VerticalContentAlignment" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="VerticalContentAlignmentComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=VerticalAlignment}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <RadioButton
                            Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalContentAlignment="{Binding SelectedValue, ElementName=VerticalContentAlignmentComboBox}"
                            Content="RadioButton" />
                    </GroupBox>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
