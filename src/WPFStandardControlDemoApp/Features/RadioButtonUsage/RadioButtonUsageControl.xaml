<UserControl
    x:Class="WPFStandardControlDemoApp.Features.RadioButtonUsage.RadioButtonUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.RadioButtonUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="1000"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="rowXamlName">RadioButtonUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="RadioButton" />

            <Expander Header="GroupName" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <UniformGrid Rows="1">
                            <GroupBox Header="GroupName=(Null)" Style="{StaticResource SubGroupBox}">
                                <StackPanel>
                                    <RadioButton
                                        x:Name="GroupNameNullARadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="A"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="GroupNameNullBRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="B" />
                                    <RadioButton
                                        x:Name="GroupNameNullCRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="C" />
                                    <RadioButton
                                        x:Name="GroupNameNullDRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="D" />
                                    <RadioButton
                                        x:Name="GroupNameNullERadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="E" />
                                    <RadioButton
                                        x:Name="GroupNameNullFRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="F" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="GroupName=1 or 2" Style="{StaticResource SubGroupBox}">
                                <StackPanel>
                                    <RadioButton
                                        x:Name="GroupName1ARadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="A(Group:1)"
                                        GroupName="1"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="GroupName1BRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="B(Group:1)"
                                        GroupName="1" />
                                    <RadioButton
                                        x:Name="GroupName1CRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="C(Group:1)"
                                        GroupName="1" />
                                    <RadioButton
                                        x:Name="GroupName2DRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="D(Group:2)"
                                        GroupName="2"
                                        IsChecked="True" />
                                    <RadioButton
                                        x:Name="GroupName2ERadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="E(Group:2)"
                                        GroupName="2" />
                                    <RadioButton
                                        x:Name="GroupName2FRadioButton"
                                        HorizontalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Content="F(Group:2)"
                                        GroupName="2" />
                                </StackPanel>
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <ToggleButton x:Name="GroupNamePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=GroupNamePopupButton}"
                        PlacementTarget="{Binding ElementName=GroupNamePopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="GroupNameNullARadioButton,GroupNameNullBRadioButton,GroupNameNullCRadioButton,GroupNameNullDRadioButton,GroupNameNullERadioButton,GroupNameNullFRadioButton,GroupName1ARadioButton,GroupName1BRadioButton,GroupName1CRadioButton,GroupName2DRadioButton,GroupName2ERadioButton,GroupName2FRadioButton">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="VerticalContentAlignment(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="VerticalContentAlignment" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="VerticalContentAlignmentComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=VerticalAlignment}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <RadioButton
                            x:Name="VerticalContentAlignmentResultRadioButton"
                            Grid.Row="1"
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            VerticalContentAlignment="{Binding SelectedValue, ElementName=VerticalContentAlignmentComboBox}"
                            Content="RadioButton" />
                    </GroupBox>
                    <ToggleButton x:Name="VerticalContentAlignmentPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=VerticalContentAlignmentPopupButton}"
                        PlacementTarget="{Binding ElementName=VerticalContentAlignmentPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="VerticalContentAlignmentComboBox,VerticalContentAlignmentResultRadioButton">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>