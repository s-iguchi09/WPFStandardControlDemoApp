<UserControl
    x:Class="WPFStandardControlDemoApp.Features.InkCanvasUsage.InkCanvasUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:cmds="clr-namespace:WPFStandardControlDemoApp.Common.Commands"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="1200"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <UserControl.Resources>
        <cmds:InkCanvasStrokesClearCommand x:Key="InkCanvasStrokesClearCommand" />
        <sys:String x:Key="rowXamlName">InkCanvasUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <TextBlock
                DockPanel.Dock="Top"
                Style="{StaticResource PageHeader}"
                Text="InkCanvas" />

            <Expander
                Header="EditingMode / ActiveEditingMode / EditingModeInverted&#10;DefaultDrawingAttributes / Strokes&#10;Background"
                IsExpanded="True"
                Style="{StaticResource ContentsExpander}">
                <DockPanel LastChildFill="True">
                    <GroupBox
                        DockPanel.Dock="Top"
                        Header="Property &amp; Edit"
                        Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Mode &amp; State" />
                            <UniformGrid Columns="3">
                                <GroupBox Header="EditingMode" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="EditingModeComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:EnumBindingSource EnumType=InkCanvasEditingMode}"
                                        SelectedIndex="1"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                                <GroupBox Header="EditingModeInverted" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="EditingModeInvertedComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:EnumBindingSource EnumType=InkCanvasEditingMode}"
                                        SelectedIndex="3"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                                <GroupBox Header="ActiveEditingMode (ReadOnly)" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        Foreground="DarkBlue"
                                        Text="{Binding ActiveEditingMode, ElementName=DemoInkCanvas}" />
                                </GroupBox>
                            </UniformGrid>

                            <TextBlock
                                Margin="0,10,0,0"
                                FontWeight="Bold"
                                Text="Appearance &amp; Pen" />
                            <UniformGrid Columns="3">
                                <GroupBox Header="Pen Color" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="PenColorComboBox"
                                        behaviors:SelectorInitialSelectionBehavior.InitialSelectedIndex="1"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:StaticBindingSource TargetType=Colors}"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                                <GroupBox Header="Pen Width" Style="{StaticResource SubGroupBox}">
                                    <Slider
                                        x:Name="PenWidthSlider"
                                        Maximum="30"
                                        Minimum="1"
                                        Style="{StaticResource PropertySliderStyle}"
                                        Value="2" />
                                </GroupBox>
                                <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="BackgroundBrushComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                        SelectedIndex="0"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                            </UniformGrid>

                            <TextBlock
                                Margin="0,10,0,0"
                                FontWeight="Bold"
                                Text="Edit Actions" />
                            <UniformGrid Columns="2">
                                <GroupBox Header="Clipboard" Style="{StaticResource SubGroupBox}">
                                    <UniformGrid Rows="1">
                                        <UniformGrid.Resources>
                                            <Style TargetType="Button">
                                                <Setter Property="Margin" Value="5,0" />
                                            </Style>
                                        </UniformGrid.Resources>
                                        <Button
                                            Command="ApplicationCommands.Copy"
                                            CommandTarget="{Binding ElementName=DemoInkCanvas}"
                                            Content="Copy" />
                                        <Button
                                            Command="ApplicationCommands.Cut"
                                            CommandTarget="{Binding ElementName=DemoInkCanvas}"
                                            Content="Cut" />
                                        <Button
                                            Command="ApplicationCommands.Paste"
                                            CommandTarget="{Binding ElementName=DemoInkCanvas}"
                                            Content="Paste" />
                                    </UniformGrid>
                                </GroupBox>
                                <GroupBox Header="Strokes Management" Style="{StaticResource SubGroupBox}">
                                    <UniformGrid Rows="1">
                                        <UniformGrid.Resources>
                                            <Style TargetType="Button">
                                                <Setter Property="Margin" Value="5,0" />
                                            </Style>
                                        </UniformGrid.Resources>
                                        <Button
                                            Command="ApplicationCommands.SelectAll"
                                            CommandTarget="{Binding ElementName=DemoInkCanvas}"
                                            Content="Select All" />
                                        <Button
                                            x:Name="ClearStrokesButton"
                                            behaviors:EventToCommandBehavior.Command="{StaticResource InkCanvasStrokesClearCommand}"
                                            behaviors:EventToCommandBehavior.CommandParameter="{Binding ElementName=DemoInkCanvas}"
                                            behaviors:EventToCommandBehavior.EventName="Click"
                                            Content="Clear All" />
                                    </UniformGrid>
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <ToggleButton
                        x:Name="CodeViewerToggleButton"
                        DockPanel.Dock="Bottom"
                        Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=CodeViewerToggleButton}"
                        PlacementTarget="{Binding ElementName=CodeViewerToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="DemoInkCanvas">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>

                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Grid>
                            <InkCanvas
                                x:Name="DemoInkCanvas"
                                behaviors:InkCanvasBehavior.PenColor="{Binding SelectedItem.Value, ElementName=PenColorComboBox}"
                                behaviors:InkCanvasBehavior.PenSize="{Binding Value, ElementName=PenWidthSlider}"
                                Background="{Binding SelectedValue, ElementName=BackgroundBrushComboBox}"
                                EditingMode="{Binding SelectedValue, ElementName=EditingModeComboBox}"
                                EditingModeInverted="{Binding SelectedValue, ElementName=EditingModeInvertedComboBox}">
                                <InkCanvas.DefaultDrawingAttributes>
                                    <DrawingAttributes Color="Black" />
                                </InkCanvas.DefaultDrawingAttributes>
                            </InkCanvas>

                            <Border
                                Margin="10"
                                Padding="8,4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#AA000000"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="11"
                                    Foreground="White"
                                    Text="Select mode: Click or Lasso to select strokes">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedValue, ElementName=EditingModeComboBox}" Value="Select">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </Grid>
                    </GroupBox>
                </DockPanel>
            </Expander>
        </DockPanel>
    </Grid>
</UserControl>