<UserControl
    x:Class="WPFStandardControlDemoApp.Features.CanvasUsage.CanvasUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="1000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="CodeViewerTextBoxStyleCustom"
            BasedOn="{StaticResource CodeViewerTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="behaviors:XamlExtractBehavior.RawXamlFileName" Value="CanvasUsageControl.xaml.raw" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <DockPanel LastChildFill="True">
            <TextBlock
                DockPanel.Dock="Top"
                Style="{StaticResource PageHeader}"
                Text="Canvas" />

            <Expander
                Header="Top&#10;Left&#10;Right&#10;Bottom&#10;ZIndex(Panel)"
                IsExpanded="True"
                Style="{StaticResource BaseContentsExpander}">
                <DockPanel LastChildFill="True">
                    <GroupBox
                        DockPanel.Dock="Top"
                        Header="Property"
                        Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <TextBlock FontWeight="Bold" Text="Rectangle A (Blue)" />
                            <UniformGrid Columns="5">
                                <GroupBox Header="Top" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="TopTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="20" />
                                </GroupBox>
                                <GroupBox Header="Left" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="LeftTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="20" />
                                </GroupBox>
                                <GroupBox Header="Right" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="RightTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="" />
                                </GroupBox>
                                <GroupBox Header="Bottom" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="BottomTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="" />
                                </GroupBox>
                                <GroupBox Header="ZIndex" Style="{StaticResource SubGroupBox}">
                                    <TextBox x:Name="ZIndexTextBox" Text="0" />
                                </GroupBox>
                            </UniformGrid>

                            <Separator Margin="0,10" />

                            <TextBlock FontWeight="Bold" Text="Rectangle B (Red)" />
                            <GroupBox
                                Width="150"
                                HorizontalAlignment="Left"
                                Header="ZIndex (Red)"
                                Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="ZIndexTextBoxRed" Text="1" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>

                    <ToggleButton
                        x:Name="CanvasDetailToggleButton"
                        DockPanel.Dock="Bottom"
                        Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=CanvasDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=CanvasDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="TargetRect" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Canvas Background="#F0F0F0" ClipToBounds="True">
                            <Rectangle
                                x:Name="TargetRect"
                                Canvas.Left="{Binding Text, ElementName=LeftTextBox, TargetNullValue={x:Static sys:Double.NaN}, FallbackValue={x:Static sys:Double.NaN}}"
                                Canvas.Top="{Binding Text, ElementName=TopTextBox, TargetNullValue={x:Static sys:Double.NaN}, FallbackValue={x:Static sys:Double.NaN}}"
                                Canvas.Right="{Binding Text, ElementName=RightTextBox, TargetNullValue={x:Static sys:Double.NaN}, FallbackValue={x:Static sys:Double.NaN}}"
                                Canvas.Bottom="{Binding Text, ElementName=BottomTextBox, TargetNullValue={x:Static sys:Double.NaN}, FallbackValue={x:Static sys:Double.NaN}}"
                                Width="100"
                                Height="100"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexTextBox, FallbackValue=0}"
                                Fill="SkyBlue"
                                Stroke="DodgerBlue"
                                StrokeThickness="2" />

                            <Rectangle
                                Canvas.Left="50"
                                Canvas.Top="50"
                                Width="100"
                                Height="100"
                                Panel.ZIndex="{Binding Text, ElementName=ZIndexTextBoxRed, FallbackValue=0}"
                                Fill="LightCoral"
                                Stroke="IndianRed"
                                StrokeThickness="2" />
                        </Canvas>
                    </GroupBox>

                </DockPanel>
            </Expander>
        </DockPanel>
    </Grid>
</UserControl>