<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ExpanderUsage.ExpanderUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:converters="clr-namespace:WPFStandardControlDemoApp.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.ExpanderUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="5000"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="RawXamlName">ExpanderUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="Expander" />
            <Expander Header="ExpandDirection" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="ExpandDirection" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="ExpandDirectionComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=ExpandDirection}"
                                SelectedIndex="0"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="ExpandDirectionExpander"
                            Content="CONTENT"
                            ExpandDirection="{Binding SelectedValue, ElementName=ExpandDirectionComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="ExpandDirectionPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ExpandDirectionPopupButton}"
                        PlacementTarget="{Binding ElementName=ExpandDirectionPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="ExpandDirectionComboBox,ExpandDirectionExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="IsExpanded" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="ExpandDirection" Style="{StaticResource SubGroupBox}">
                            <CheckBox
                                x:Name="IsExpandedCheckBox"
                                VerticalContentAlignment="Center"
                                Content="IsExpanded" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="IsExpandedExpander"
                            Content="CONTENT"
                            Header="Expander"
                            IsExpanded="{Binding IsChecked, ElementName=IsExpandedCheckBox}" />
                    </GroupBox>
                    <ToggleButton x:Name="IsExpandedPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsExpandedPopupButton}"
                        PlacementTarget="{Binding ElementName=IsExpandedPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsExpandedCheckBox,IsExpandedExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="Header(ContentControl)&#10;HasHeader(ContentControl)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Header" Style="{StaticResource SubGroupBox}">
                            <TextBox x:Name="HeaderTextBox" Text="HEADER" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <Expander
                                x:Name="HeaderExpander"
                                Header="{Binding Text, ElementName=HeaderTextBox, Converter={converters:WhiteSpaceToNullConverter}}"
                                IsExpanded="True" />
                            <GroupBox Header="HasHeader" Style="{StaticResource SubGroupBox}">
                                <TextBlock x:Name="HasHeaderTextBlock" Text="{Binding HasHeader, ElementName=HeaderExpander}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="HeaderPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=HeaderPopupButton}"
                        PlacementTarget="{Binding ElementName=HeaderPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="HeaderTextBox,HeaderExpander,HasHeaderTextBlock">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="Content(ContentControl)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="ContentTextBox" Text="CONTENT" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="ContentExpander"
                            Content="{Binding Text, ElementName=ContentTextBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="ContentPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ContentPopupButton}"
                        PlacementTarget="{Binding ElementName=ContentPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="ContentTextBox,ContentExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="Padding(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="PaddingText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="Padding" Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="PaddingTextBox" behaviors:TextBoxDoubleInputBehavior.IsEnabled="True" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="PaddingExpander"
                            Padding="{Binding Text, ElementName=PaddingTextBox, Converter={converters:StringToThicknessConverter}}"
                            Content="{Binding Text, ElementName=PaddingText}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="PaddingPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=PaddingPopupButton}"
                        PlacementTarget="{Binding ElementName=PaddingPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="PaddingText,PaddingTextBox,PaddingExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="FontWeight(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontWeightText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="FontWeight" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontWeightComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontWeights}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>

                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="FontWeightExpander"
                            Content="{Binding Text, ElementName=FontWeightText}"
                            FontWeight="{Binding SelectedValue, ElementName=FontWeightComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="FontWeightPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=FontWeightPopupButton}"
                        PlacementTarget="{Binding ElementName=FontWeightPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="FontWeightText,FontWeightComboBox,FontWeightExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="FontStyle(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontStyleText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="FontStyle" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontStyleComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontStyles}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="FontStyleExpander"
                            Content="{Binding Text, ElementName=FontStyleText}"
                            FontStyle="{Binding SelectedValue, ElementName=FontStyleComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="FontStylePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=FontStylePopupButton}"
                        PlacementTarget="{Binding ElementName=FontStylePopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="FontStyleText,FontStyleComboBox,FontStyleExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="FontStretch(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontStretchText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="FontStretch" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontStretchComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontStretches}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="FontStretchExpander"
                            Content="{Binding Text, ElementName=FontStretchText}"
                            FontStretch="{Binding SelectedValue, ElementName=FontStretchComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="FontStretchPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=FontStretchPopupButton}"
                        PlacementTarget="{Binding ElementName=FontStretchPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="FontStretchText,FontStretchComboBox,FontStretchExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="FontSize(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontSizeText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="FontSize" Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="FontSizeTextBox" behaviors:TextBoxDoubleInputBehavior.IsEnabled="True" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="FontSizeExpander"
                            Content="{Binding Text, ElementName=FontSizeText}"
                            FontSize="{Binding Text, ElementName=FontSizeTextBox, Converter={converters:ToDoubleConverter}}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="FontSizePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=FontSizePopupButton}"
                        PlacementTarget="{Binding ElementName=FontSizePopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="FontSizeText,FontSizeTextBox,FontSizeExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="FontFamily(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontFamilyText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="FontFamily" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontFamilyComboBox"
                                    DisplayMemberPath="Source"
                                    ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"
                                    SelectedIndex="0" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="FontFamilyExpander"
                            Content="{Binding Text, ElementName=FontFamilyText}"
                            FontFamily="{Binding SelectedValue, ElementName=FontFamilyComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="FontFamilyPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=FontFamilyPopupButton}"
                        PlacementTarget="{Binding ElementName=FontFamilyPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="FontFamilyText,FontFamilyComboBox,FontFamilyExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="Background(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="BackgroundText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="BackgroundComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="BackgroundExpander"
                            Background="{Binding SelectedItem.Value, ElementName=BackgroundComboBox}"
                            Content="{Binding Text, ElementName=BackgroundText}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="BackgroundPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BackgroundPopupButton}"
                        PlacementTarget="{Binding ElementName=BackgroundPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="BackgroundText,BackgroundComboBox,BackgroundExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="Foreground(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="ForegroundText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <GroupBox Header="Foreground" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="ForegroundComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="ForegroundExpander"
                            Content="{Binding Text, ElementName=ForegroundText}"
                            Foreground="{Binding SelectedItem.Value, ElementName=ForegroundComboBox}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="ForegroundPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ForegroundPopupButton}"
                        PlacementTarget="{Binding ElementName=ForegroundPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="ForegroundText,ForegroundComboBox,ForegroundExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="BorderBrush(Control)&#10;BorderThickness(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="BorderText"
                                    AcceptsReturn="True"
                                    Text="CONTENT" />
                            </GroupBox>
                            <UniformGrid Rows="1">
                                <GroupBox Header="BorderThickness" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="BorderThicknessTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="1" />
                                </GroupBox>
                                <GroupBox Header="BorderBrush" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="BorderBrushComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                        SelectedIndex="0"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Expander
                            x:Name="BorderExpander"
                            BorderBrush="{Binding SelectedValue, ElementName=BorderBrushComboBox}"
                            BorderThickness="{Binding Text, ElementName=BorderThicknessTextBox}"
                            Content="{Binding Text, ElementName=BorderText}"
                            Header="Expander"
                            IsExpanded="True" />
                    </GroupBox>
                    <ToggleButton x:Name="BorderPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BorderPopupButton}"
                        PlacementTarget="{Binding ElementName=BorderPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="BorderText,BorderThicknessTextBox,BorderBrushComboBox,BorderExpander">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
