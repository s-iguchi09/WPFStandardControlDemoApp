<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ToggleButtonUsage.ToggleButtonUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.ToggleButtonUsage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="RawXamlName">ToggleButtonUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="ToggleButton" />
            <Expander Header="IsChecked" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <UniformGrid Columns="3">
                        <StackPanel>
                            <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                                <GroupBox Header="IsChecked=(Null)" Style="{StaticResource SubGroupBox}">
                                    <ToggleButton
                                        x:Name="IsCheckedNullCheckBox"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Content="ToggleButton"
                                        IsChecked="{x:Null}" />
                                </GroupBox>
                            </GroupBox>
                            <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                                <GroupBox Header="IsChecked" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Text="{Binding IsChecked, ElementName=IsCheckedNullCheckBox, TargetNullValue=(Null)}" />
                                </GroupBox>
                            </GroupBox>
                        </StackPanel>
                        <StackPanel>
                            <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                                <GroupBox Header="IsChecked=False" Style="{StaticResource SubGroupBox}">
                                    <ToggleButton
                                        x:Name="IsCheckedFalseCheckBox"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Content="ToggleButton"
                                        IsChecked="False" />
                                </GroupBox>
                            </GroupBox>
                            <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                                <GroupBox Header="IsChecked" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Text="{Binding IsChecked, ElementName=IsCheckedFalseCheckBox}" />
                                </GroupBox>
                            </GroupBox>
                        </StackPanel>
                        <StackPanel>
                            <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                                <GroupBox Header="IsChecked=True" Style="{StaticResource SubGroupBox}">
                                    <ToggleButton
                                        x:Name="IsCheckedTrueCheckBox"
                                        Grid.Row="3"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Content="ToggleButton"
                                        IsChecked="True" />
                                </GroupBox>
                            </GroupBox>
                            <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                                <GroupBox Header="IsChecked" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        Grid.Row="3"
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Text="{Binding IsChecked, ElementName=IsCheckedTrueCheckBox}" />
                                </GroupBox>
                            </GroupBox>
                        </StackPanel>
                    </UniformGrid>
                    <ToggleButton x:Name="IsCheckedPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsCheckedPopupButton}"
                        PlacementTarget="{Binding ElementName=IsCheckedPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsCheckedNullCheckBox,IsCheckedFalseCheckBox,IsCheckedTrueCheckBox">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
            <Expander Header="IsThreeState" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <UniformGrid Columns="2">
                        <StackPanel>
                            <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                                <GroupBox Header="IsThreeState=True" Style="{StaticResource SubGroupBox}">
                                    <ToggleButton
                                        x:Name="IsThreeStateTrueButton"
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Content="ToggleButton"
                                        IsThreeState="True" />
                                </GroupBox>
                            </GroupBox>
                            <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                                <GroupBox Header="IsChecked" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        Grid.Row="1"
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Text="{Binding IsChecked, ElementName=IsThreeStateTrueButton, TargetNullValue=(Null)}" />
                                </GroupBox>
                            </GroupBox>
                        </StackPanel>
                        <StackPanel>
                            <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                                <GroupBox Header="IsThreeState=False" Style="{StaticResource SubGroupBox}">
                                    <ToggleButton
                                        x:Name="IsThreeStateFalseButton"
                                        Grid.Row="2"
                                        Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Content="ToggleButton"
                                        IsThreeState="False" />
                                </GroupBox>
                            </GroupBox>
                            <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                                <GroupBox Header="IsChecked" Style="{StaticResource SubGroupBox}">
                                    <TextBlock
                                        Grid.Row="2"
                                        Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Text="{Binding IsChecked, ElementName=IsThreeStateFalseButton}" />
                                </GroupBox>
                            </GroupBox>
                        </StackPanel>
                    </UniformGrid>
                    <ToggleButton x:Name="IsThreeStatePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsThreeStatePopupButton}"
                        PlacementTarget="{Binding ElementName=IsThreeStatePopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsThreeStateTrueButton,IsThreeStateFalseButton">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
