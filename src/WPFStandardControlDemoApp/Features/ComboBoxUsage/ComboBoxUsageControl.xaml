<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ComboBoxUsage.ComboBoxUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:linq="clr-namespace:System.Linq;assembly=System.Core"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.ComboBoxUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DataContext="{d:DesignInstance local:ComboBoxUsageViewModel,
                                     IsDesignTimeCreatable=True}"
    d:DesignHeight="3000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="CodeViewerTextBoxStyleCustom"
            BasedOn="{StaticResource CodeViewerTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="behaviors:XamlExtractBehavior.RawXamlFileName" Value="ComboBoxUsageControl.xaml.raw" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="ComboBox" />

            <Expander Header="IsDropDownOpen" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="IsDropDownOpen"
                            VerticalContentAlignment="Center"
                            Content="IsDropDownOpen" />
                    </GroupBox>
                    <ComboBox
                        x:Name="IsDropDownOpenComboBox"
                        DisplayMemberPath="Name"
                        IsDropDownOpen="{Binding IsChecked, ElementName=IsDropDownOpen}"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value" />
                    <ToggleButton x:Name="IsDropDownOpenPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsDropDownOpenPopupButton}"
                        PlacementTarget="{Binding ElementName=IsDropDownOpenPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="IsDropDownOpen,IsDropDownOpenComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="IsEditable" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="IsEditable"
                            VerticalContentAlignment="Center"
                            Content="IsEditable" />
                    </GroupBox>
                    <ComboBox
                        x:Name="IsEditableComboBox"
                        DisplayMemberPath="Name"
                        IsEditable="{Binding IsChecked, ElementName=IsEditable}"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <GroupBox Header="SelectedValue" Style="{StaticResource SubGroupBox}">
                            <TextBlock Text="{Binding SelectedValue, ElementName=IsEditableComboBox}" />
                        </GroupBox>
                    </GroupBox>
                    <ToggleButton x:Name="IsEditablePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsEditablePopupButton}"
                        PlacementTarget="{Binding ElementName=IsEditablePopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="IsEditable,IsEditableComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="IsReadOnly" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="IsReadOnly"
                            VerticalContentAlignment="Center"
                            Content="IsReadOnly" />
                    </GroupBox>
                    <ComboBox
                        x:Name="IsReadOnlyComboBox"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        IsReadOnly="{Binding IsChecked, ElementName=IsReadOnly}"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <GroupBox Header="SelectedValue" Style="{StaticResource SubGroupBox}">
                            <TextBlock Text="{Binding SelectedValue, ElementName=IsReadOnlyComboBox}" />
                        </GroupBox>
                    </GroupBox>
                    <ToggleButton x:Name="IsReadOnlyPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsReadOnlyPopupButton}"
                        PlacementTarget="{Binding ElementName=IsReadOnlyPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="IsReadOnly,IsReadOnlyComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="MaxDropDownHeight" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="MaxDropDownHeight" Style="{StaticResource SubGroupBox}">
                            <TextBox
                                x:Name="MaxDropDownHeight"
                                behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                Text="100" />
                        </GroupBox>
                    </GroupBox>
                    <ComboBox
                        x:Name="MaxDropDownHeightComboBox"
                        DisplayMemberPath="Name"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        MaxDropDownHeight="{Binding Text, ElementName=MaxDropDownHeight}"
                        SelectedValuePath="Value" />
                    <ToggleButton x:Name="MaxDropDownHeightPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=MaxDropDownHeightPopupButton}"
                        PlacementTarget="{Binding ElementName=MaxDropDownHeightPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="MaxDropDownHeight,MaxDropDownHeightComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Text" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <ComboBox
                        x:Name="TextComboBox"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Text" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding Text, ElementName=TextComboBox}" />
                            </GroupBox>
                            <GroupBox Header="SelectedValue" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedValue, ElementName=TextComboBox}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="TextPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=TextPopupButton}"
                        PlacementTarget="{Binding ElementName=TextPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="TextComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="StaysOpenOnEdit" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="StaysOpenOnEdit"
                            VerticalContentAlignment="Center"
                            Content="StaysOpenOnEdit" />
                    </GroupBox>
                    <ComboBox
                        x:Name="StaysOpenOnEditComboBox"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value"
                        StaysOpenOnEdit="{Binding IsChecked, ElementName=StaysOpenOnEdit}" />
                    <ToggleButton x:Name="StaysOpenOnEditPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=StaysOpenOnEditPopupButton}"
                        PlacementTarget="{Binding ElementName=StaysOpenOnEditPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="StaysOpenOnEdit,StaysOpenOnEditComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="ShouldPreserveUserEnteredPrefix" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="ShouldPreserveUserEnteredPrefix"
                            VerticalContentAlignment="Center"
                            Content="ShouldPreserveUserEnteredPrefix" />
                    </GroupBox>
                    <ComboBox
                        x:Name="ShouldPreserveUserEnteredPrefixComboBox"
                        DisplayMemberPath="Name"
                        IsEditable="True"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value"
                        ShouldPreserveUserEnteredPrefix="{Binding IsChecked, ElementName=ShouldPreserveUserEnteredPrefix}" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Text" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding Text, ElementName=ShouldPreserveUserEnteredPrefixComboBox}" />
                            </GroupBox>
                            <GroupBox Header="SelectedValue" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedValue, ElementName=ShouldPreserveUserEnteredPrefixComboBox}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="ShouldPreserveUserEnteredPrefixPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=ShouldPreserveUserEnteredPrefixPopupButton}"
                        PlacementTarget="{Binding ElementName=ShouldPreserveUserEnteredPrefixPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="ShouldPreserveUserEnteredPrefix,ShouldPreserveUserEnteredPrefixComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="SelectedIndex(Selector)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <ComboBox
                        x:Name="SelectedIndexComboBox"
                        DisplayMemberPath="Name"
                        ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                        SelectedValuePath="Value" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <GroupBox Header="SelectedIndex" Style="{StaticResource SubGroupBox}">
                            <TextBlock Text="{Binding SelectedIndex, ElementName=SelectedIndexComboBox}" />
                        </GroupBox>
                    </GroupBox>
                    <ToggleButton x:Name="SelectedIndexPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=SelectedIndexPopupButton}"
                        PlacementTarget="{Binding ElementName=SelectedIndexPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="SelectedIndexComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="SelectedItem(Selector)" Style="{StaticResource BaseContentsExpander}">
                <UniformGrid Rows="1">
                    <StackPanel>
                        <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                            <GroupBox Header="ItemsSource=Values" Style="{StaticResource SubGroupBox}">
                                <ComboBox x:Name="SelectedItemSimpleComboBox">
                                    <sys:DayOfWeek>Sunday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Monday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Tuesday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Wednesday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Thursday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Friday</sys:DayOfWeek>
                                    <sys:DayOfWeek>Saturday</sys:DayOfWeek>
                                </ComboBox>
                            </GroupBox>
                        </GroupBox>
                        <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                            <GroupBox Header="SelectedItem" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedItem, ElementName=SelectedItemSimpleComboBox}" />
                            </GroupBox>
                        </GroupBox>
                        <ToggleButton x:Name="SelectedItemSimplePopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                        <Popup
                            IsOpen="{Binding IsChecked, ElementName=SelectedItemSimplePopupButton}"
                            PlacementTarget="{Binding ElementName=SelectedItemSimplePopupButton}"
                            StaysOpen="False">
                            <Border Style="{StaticResource PopupBorderStyle}">
                                <TextBox behaviors:XamlExtractBehavior.TargetNames="SelectedItemSimpleComboBox,SelectedItemDicComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                            </Border>
                        </Popup>
                    </StackPanel>
                    <StackPanel>
                        <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                            <GroupBox Header="ItemsSource=Classes" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="SelectedItemDicComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </GroupBox>
                        <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                            <GroupBox Header="SelectedItem" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedValue, ElementName=SelectedItemDicComboBox}" />
                            </GroupBox>
                        </GroupBox>
                    </StackPanel>
                </UniformGrid>
            </Expander>

            <Expander Header="SelectedValue(Selector)&#10;SelectedValuePath(Selector)&#10;DisplayMemberPath(ItemsControl)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="ItemsSource=Classes&#10;DisplayMemberPath=Value&#10;SelectedValuePath=Key" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="PathComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <UniformGrid Rows="1">
                            <GroupBox Header="SelectedItem" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedItem, ElementName=PathComboBox}" />
                            </GroupBox>
                            <GroupBox Header="SelectedValue" Style="{StaticResource SubGroupBox}">
                                <TextBlock Text="{Binding SelectedValue, ElementName=PathComboBox}" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <ToggleButton x:Name="PathPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=PathPopupButton}"
                        PlacementTarget="{Binding ElementName=PathPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="PathComboBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="IsSynchronizedWithCurrentItem(ItemsControl)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <CheckBox
                            x:Name="IsSynchronizedWithCurrentItem"
                            VerticalContentAlignment="Center"
                            Content="IsSynchronizedWithCurrentItem"
                            IsChecked="True" />
                    </GroupBox>
                    <UniformGrid Rows="1">
                        <GroupBox Header="ComboBox1" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="IsSynchronizedWithCurrentItemComboBox1"
                                DisplayMemberPath="Name"
                                IsSynchronizedWithCurrentItem="{Binding IsChecked, ElementName=IsSynchronizedWithCurrentItem}"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=sys:DayOfWeek}"
                                SelectedValuePath="Value" />
                        </GroupBox>
                        <GroupBox Header="ComboBox2" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="IsSynchronizedWithCurrentItemComboBox2"
                                DisplayMemberPath="Name"
                                IsSynchronizedWithCurrentItem="{Binding IsChecked, ElementName=IsSynchronizedWithCurrentItem}"
                                ItemsSource="{Binding ItemsSource, ElementName=IsSynchronizedWithCurrentItemComboBox1}"
                                SelectedValuePath="Value" />
                        </GroupBox>
                        <GroupBox Header="ComboBox3" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="IsSynchronizedWithCurrentItemComboBox3"
                                DisplayMemberPath="Name"
                                IsSynchronizedWithCurrentItem="{Binding IsChecked, ElementName=IsSynchronizedWithCurrentItem}"
                                ItemsSource="{Binding ItemsSource, ElementName=IsSynchronizedWithCurrentItemComboBox1}"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </UniformGrid>
                    <ToggleButton x:Name="IsSynchronizedWithCurrentItemPopupButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=IsSynchronizedWithCurrentItemPopupButton}"
                        PlacementTarget="{Binding ElementName=IsSynchronizedWithCurrentItemPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="IsSynchronizedWithCurrentItem,IsSynchronizedWithCurrentItemComboBox1,IsSynchronizedWithCurrentItemComboBox2,IsSynchronizedWithCurrentItemComboBox3" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>