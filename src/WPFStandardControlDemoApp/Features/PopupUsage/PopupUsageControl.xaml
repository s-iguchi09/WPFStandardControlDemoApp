<UserControl
    x:Class="WPFStandardControlDemoApp.Features.PopupUsage.PopupUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:converters="clr-namespace:WPFStandardControlDemoApp.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    d:DesignHeight="1500"
    d:DesignWidth="800"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="RawXamlName">PopupUsageControl.xaml.raw</sys:String>
        <converters:RectConverter x:Key="RectConverter" />
        <Border
            x:Key="PopupChildContent"
            Background="LightYellow"
            BorderBrush="Orange"
            BorderThickness="2"
            CornerRadius="5">
            <StackPanel>
                <TextBlock FontWeight="Bold" Text="Popup Content" />
                <TextBlock Text="This is a Child element." />
            </StackPanel>
        </Border>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="Popup" />

            <Expander Header="IsOpen&#10;StaysOpen&#10;AllowsTransparency" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Columns="3">
                            <GroupBox Header="IsOpen" Style="{StaticResource SubGroupBox}">
                                <CheckBox
                                    x:Name="IsOpenCheckBox"
                                    VerticalContentAlignment="Center"
                                    Content="IsOpen" />
                            </GroupBox>
                            <GroupBox Header="StaysOpen" Style="{StaticResource SubGroupBox}">
                                <CheckBox
                                    x:Name="StaysOpenCheckBox"
                                    VerticalContentAlignment="Center"
                                    Content="StaysOpen"
                                    IsChecked="True" />
                            </GroupBox>
                            <GroupBox Header="AllowsTransparency" Style="{StaticResource SubGroupBox}">
                                <CheckBox
                                    x:Name="AllowsTransparencyCheckBox"
                                    VerticalContentAlignment="Center"
                                    Content="AllowsTransparency"
                                    IsChecked="True" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Grid>
                            <Button x:Name="BasicPlacementTarget" Content="Placement Target" />
                            <Popup
                                x:Name="BasicPopup"
                                AllowsTransparency="{Binding IsChecked, ElementName=AllowsTransparencyCheckBox}"
                                IsOpen="{Binding IsChecked, ElementName=IsOpenCheckBox}"
                                Placement="Bottom"
                                PlacementTarget="{Binding ElementName=BasicPlacementTarget}"
                                StaysOpen="{Binding IsChecked, ElementName=StaysOpenCheckBox}">
                                <Border
                                    Background="White"
                                    BorderBrush="Gray"
                                    BorderThickness="1">
                                    <TextBlock Text="Basic Popup Content" />
                                </Border>
                            </Popup>
                        </Grid>
                    </GroupBox>
                    <ToggleButton x:Name="BasicDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=BasicDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=BasicDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsOpenCheckBox,StaysOpenCheckBox,AllowsTransparencyCheckBox,BasicPopup">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Placement&#10;HorizontalOffset&#10;VerticalOffset" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Placement" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="PlacementComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=primitives:PlacementMode}"
                                    SelectedIndex="2"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <UniformGrid Columns="2">
                                <GroupBox Header="HorizontalOffset" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="HorizontalOffsetTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="0" />
                                </GroupBox>
                                <GroupBox Header="VerticalOffset" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="VerticalOffsetTextBox"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="0" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Grid>
                            <ToggleButton
                                x:Name="OffsetPopupToggle"
                                VerticalContentAlignment="Center"
                                Content="Toggle Popup" />
                            <Popup
                                x:Name="OffsetPopup"
                                HorizontalOffset="{Binding Text, ElementName=HorizontalOffsetTextBox}"
                                IsOpen="{Binding IsChecked, ElementName=OffsetPopupToggle}"
                                Placement="{Binding SelectedValue, ElementName=PlacementComboBox}"
                                PlacementTarget="{Binding ElementName=OffsetPopupToggle}"
                                VerticalOffset="{Binding Text, ElementName=VerticalOffsetTextBox}">
                                <Border
                                    Background="LightBlue"
                                    BorderBrush="Blue"
                                    BorderThickness="1">
                                    <TextBlock Text="Offset &amp; Placement Popup" />
                                </Border>
                            </Popup>
                        </Grid>
                    </GroupBox>
                    <ToggleButton x:Name="OffsetDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=OffsetDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=OffsetDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="PlacementComboBox,HorizontalOffsetTextBox,VerticalOffsetTextBox,OffsetPopup">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="PopupAnimation" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="PopupAnimation" Style="{StaticResource SubGroupBox}">
                            <ComboBox
                                x:Name="AnimationComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{markupextensions:EnumBindingSource EnumType=primitives:PopupAnimation}"
                                SelectedIndex="1"
                                SelectedValuePath="Value" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Grid>
                            <ToggleButton x:Name="AnimationPopupToggle" Content="Show Animation Popup" />
                            <Popup
                                x:Name="AnimationPopup"
                                AllowsTransparency="True"
                                IsOpen="{Binding IsChecked, ElementName=AnimationPopupToggle}"
                                PlacementTarget="{Binding ElementName=AnimationPopupToggle}"
                                PopupAnimation="{Binding SelectedValue, ElementName=AnimationComboBox}">
                                <Border Background="#EE333333" CornerRadius="5">
                                    <TextBlock Foreground="White" Text="Animating..." />
                                </Border>
                            </Popup>
                        </Grid>
                    </GroupBox>
                    <ToggleButton x:Name="AnimationDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=AnimationDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=AnimationDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="AnimationComboBox,AnimationPopup">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Child&#10;PlacementRectangle" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Placement" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="RectPlacementComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=primitives:PlacementMode}"
                                    SelectedIndex="2"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <UniformGrid Columns="4">
                                <GroupBox Header="PlacementRectangle X" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="RectX"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="0" />
                                </GroupBox>
                                <GroupBox Header="PlacementRectangle Y" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="RectY"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="0" />
                                </GroupBox>
                                <GroupBox Header="PlacementRectangle Width" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="RectW"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="100" />
                                </GroupBox>
                                <GroupBox Header="PlacementRectangle Height" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="RectH"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="50" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Grid>
                            <ToggleButton x:Name="RectPopupToggle" Content="Open Rect Popup" />
                            <Popup
                                x:Name="RectPopup"
                                IsOpen="{Binding IsChecked, ElementName=RectPopupToggle}"
                                Placement="{Binding SelectedValue, ElementName=RectPlacementComboBox}">
                                <Popup.PlacementRectangle>
                                    <MultiBinding Converter="{StaticResource RectConverter}">
                                        <Binding ElementName="RectX" Path="Text" />
                                        <Binding ElementName="RectY" Path="Text" />
                                        <Binding ElementName="RectW" Path="Text" />
                                        <Binding ElementName="RectH" Path="Text" />
                                    </MultiBinding>
                                </Popup.PlacementRectangle>
                                <StaticResource ResourceKey="PopupChildContent" />
                            </Popup>
                        </Grid>
                    </GroupBox>
                    <ToggleButton x:Name="RectDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=RectDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=RectDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource RawXamlName}" behaviors:XamlExtractBehavior.TargetNames="RectPlacementComboBox,RectPopup">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>