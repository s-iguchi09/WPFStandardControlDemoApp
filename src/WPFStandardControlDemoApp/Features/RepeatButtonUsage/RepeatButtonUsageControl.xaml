<UserControl
    x:Class="WPFStandardControlDemoApp.Features.RepeatButtonUsage.RepeatButtonUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behavior="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.RepeatButtonUsage"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="RepeatButton" />
            <Expander Header="Delay&#10;Interval" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Rows="1">
                            <GroupBox Header="Delay" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="Delay"
                                    behavior:TextBoxIntOnlyBehavior.Enable="True"
                                    InputMethod.IsInputMethodEnabled="False"
                                    Text="100" />
                            </GroupBox>
                            <GroupBox Header="Interval" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="Interval"
                                    behavior:TextBoxIntOnlyBehavior.Enable="True"
                                    InputMethod.IsInputMethodEnabled="False"
                                    Text="100" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <RepeatButton
                        Click="RepeatButton_Click"
                        Content="Hold down"
                        Delay="{Binding Text, ElementName=Delay}"
                        Interval="{Binding Text, ElementName=Interval}" />
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <GroupBox Header="ClickDateTime" Style="{StaticResource SubGroupBox}">
                            <TextBlock x:Name="ClickDateTime" />
                        </GroupBox>
                    </GroupBox>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>

