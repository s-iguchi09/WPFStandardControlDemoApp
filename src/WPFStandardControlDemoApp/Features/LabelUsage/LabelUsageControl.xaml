<UserControl
    x:Class="WPFStandardControlDemoApp.Features.LabelUsage.LabelUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:converters="clr-namespace:WPFStandardControlDemoApp.Common.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.LabelUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="4000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:StringToThicknessConverter x:Key="StringToThicknessConverter" />
        <converters:ToDoubleConverter x:Key="ToDoubleConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="Label" />
            <Expander Header="Target" Style="{StaticResource ContentsExpander}">
                <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="_Name(Press Alt+N)"
                            Target="{Binding ElementName=NameText}" />
                        <TextBox
                            x:Name="NameText"
                            Grid.Row="0"
                            Grid.Column="1" />
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Content="_Age(Press Alt+A)"
                            Target="{Binding ElementName=AgeText}" />
                        <TextBox
                            x:Name="AgeText"
                            Grid.Row="1"
                            Grid.Column="1" />
                    </Grid>
                </GroupBox>
            </Expander>
            <Expander Header="Content(ContentControl)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                            <TextBox
                                x:Name="ContentText"
                                AcceptsReturn="True"
                                Text="LABEL" />
                        </GroupBox>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=ContentText}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="Padding(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="PaddingText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="Padding" Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="PaddingTextBox" behaviors:TextBoxDoubleInputBehavior.IsEnabled="True" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Padding="{Binding Text, ElementName=PaddingTextBox, Converter={StaticResource StringToThicknessConverter}}" Content="{Binding Text, ElementName=PaddingText}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="FontWeight(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontWeightText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="FontWeight" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontWeightComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontWeights}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>

                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=FontWeightText}" FontWeight="{Binding SelectedValue, ElementName=FontWeightComboBox}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="FontStyle(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontStyleText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="FontStyle" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontStyleComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontStyles}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=FontStyleText}" FontStyle="{Binding SelectedValue, ElementName=FontStyleComboBox}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="FontStretch(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontStretchText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="FontStretch" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontStretchComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=FontStretches}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=FontStretchText}" FontStretch="{Binding SelectedValue, ElementName=FontStretchComboBox}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="FontSize(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontSizeText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="FontSize" Style="{StaticResource SubGroupBox}">
                                <TextBox x:Name="FontSizeTextBox" behaviors:TextBoxDoubleInputBehavior.IsEnabled="True" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=FontSizeText}" FontSize="{Binding Text, ElementName=FontSizeTextBox, Converter={StaticResource ToDoubleConverter}}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="FontFamily(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="FontFamilyText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="FontFamily" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="FontFamilyComboBox"
                                    DisplayMemberPath="Source"
                                    ItemsSource="{Binding Source={x:Static Fonts.SystemFontFamilies}}"
                                    SelectedIndex="0" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=FontFamilyText}" FontFamily="{Binding SelectedValue, ElementName=FontFamilyComboBox}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="Background(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="BackgroundText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="BackgroundComboBox"
                                    behaviors:SelectorInitialSelectionBehavior.InitialSelectedIndex="0"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Background="{Binding SelectedItem.Value, ElementName=BackgroundComboBox}" Content="{Binding Text, ElementName=BackgroundText}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="Foreground(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="ForegroundText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <GroupBox Header="Foreground" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="ForegroundComboBox"
                                    behaviors:SelectorInitialSelectionBehavior.InitialSelectedIndex="0"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label Content="{Binding Text, ElementName=ForegroundText}" Foreground="{Binding SelectedItem.Value, ElementName=ForegroundComboBox}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="BorderBrush(Control)&#10;BorderThickness(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="BorderText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <UniformGrid Rows="1">
                                <GroupBox Header="BorderThickness" Style="{StaticResource SubGroupBox}">
                                    <TextBox
                                        x:Name="BorderThicknessText"
                                        behaviors:TextBoxDoubleInputBehavior.IsEnabled="True"
                                        Text="1" />
                                </GroupBox>
                                <GroupBox Header="BorderBrush" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="BorderBrushComboBox"
                                        behaviors:SelectorInitialSelectionBehavior.InitialSelectedIndex="0"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Label
                            BorderBrush="{Binding SelectedValue, ElementName=BorderBrushComboBox}"
                            BorderThickness="{Binding Text, ElementName=BorderThicknessText}"
                            Content="{Binding Text, ElementName=BorderText}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
            <Expander Header="HorizontalContentAlignment(Control)&#10;VerticalContentAlignment(Control)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Content" Style="{StaticResource SubGroupBox}">
                                <TextBox
                                    x:Name="AlignmentText"
                                    AcceptsReturn="True"
                                    Text="LABEL" />
                            </GroupBox>
                            <UniformGrid Rows="1">
                                <GroupBox Header="HorizontalContentAlignment" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="HorizontalContentAlignmentComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:EnumBindingSource EnumType=HorizontalAlignment}"
                                        SelectedIndex="0"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                                <GroupBox Header="VerticalContentAlignment" Style="{StaticResource SubGroupBox}">
                                    <ComboBox
                                        x:Name="VerticalContentAlignmentComboBox"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{markupextensions:EnumBindingSource EnumType=VerticalAlignment}"
                                        SelectedIndex="0"
                                        SelectedValuePath="Value" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox
                        Height="150"
                        Header="Result"
                        Style="{StaticResource ResultGroupBox}">
                        <Label
                            HorizontalContentAlignment="{Binding SelectedValue, ElementName=HorizontalContentAlignmentComboBox}"
                            VerticalContentAlignment="{Binding SelectedValue, ElementName=VerticalContentAlignmentComboBox}"
                            BorderBrush="Black"
                            BorderThickness="1"
                            Content="{Binding Text, ElementName=AlignmentText}" />
                    </GroupBox>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
