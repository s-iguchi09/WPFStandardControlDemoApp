<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ViewboxUsage.ViewboxUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers"
    xmlns:local="clr-namespace:WPFStandardControlDemoApp.Features.ViewboxUsage"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="500"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="CodeViewerTextBoxStyleCustom"
            BasedOn="{StaticResource CodeViewerTextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="behaviors:XamlExtractBehavior.RawXamlFileName" Value="ViewboxUsageControl.xaml.raw" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <DockPanel LastChildFill="True">
            <TextBlock
                DockPanel.Dock="Top"
                Style="{StaticResource PageHeader}"
                Text="Viewbox" />
            <Expander Header="Stretch&#10;StretchDirection" Style="{StaticResource ContentsExpander}">
                <DockPanel LastChildFill="True">
                    <GroupBox
                        DockPanel.Dock="Top"
                        Header="Property"
                        Style="{StaticResource PropertyGroupBox}">
                        <StackPanel>
                            <GroupBox Header="Stretch" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="StretchComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=Stretch}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <GroupBox Header="StretchDirection" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="StretchDirectionComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=StretchDirection}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton
                        x:Name="StretchPopupButton"
                        DockPanel.Dock="Bottom"
                        Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=StretchPopupButton}"
                        PlacementTarget="{Binding ElementName=StretchPopupButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <TextBox behaviors:XamlExtractBehavior.TargetNames="StretchComboBox,StretchDirectionComboBox,StretchViewBox" Style="{StaticResource CodeViewerTextBoxStyleCustom}" />
                        </Border>
                    </Popup>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <Viewbox
                            x:Name="StretchViewBox"
                            Stretch="{Binding SelectedValue, ElementName=StretchComboBox}"
                            StretchDirection="{Binding SelectedValue, ElementName=StretchDirectionComboBox}">
                            <Label
                                Padding="20"
                                BorderBrush="Black"
                                BorderThickness="1"
                                Content="Item1" />
                        </Viewbox>
                    </GroupBox>
                </DockPanel>
            </Expander>
        </DockPanel>
    </Grid>
</UserControl>
