<UserControl
    x:Class="WPFStandardControlDemoApp.Features.ToolBarUsage.ToolBarUsageControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markupextensions="clr-namespace:WPFStandardControlDemoApp.Common.MarkupExtensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    d:DesignHeight="3000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <sys:String x:Key="rowXamlName">ToolBarUsageControl.xaml.raw</sys:String>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Style="{StaticResource PageHeader}" Text="ToolBar" />

            <Expander Header="HasOverflowItems (ToolBar)&#10;IsOverflowItem (ToolBar)&#10;IsOverflowOpen (ToolBar)&#10;OverflowMode (ToolBar)" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Rows="1">
                            <GroupBox Header="IsOverflowOpen" Style="{StaticResource SubGroupBox}">
                                <CheckBox
                                    x:Name="IsOverflowOpenCheckBox"
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="IsOverflowOpen" />
                            </GroupBox>
                            <GroupBox Header="OverflowMode" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="OverflowModeComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=OverflowMode}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <GroupBox Header="Width" Style="{StaticResource SubGroupBox}">
                                <Slider
                                    x:Name="WidthSlider"
                                    VerticalAlignment="Center"
                                    AutoToolTipPlacement="BottomRight"
                                    LargeChange="50"
                                    Maximum="400"
                                    Minimum="100"
                                    TickFrequency="50"
                                    TickPlacement="BottomRight"
                                    Value="200" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <ToolBar
                                x:Name="OverflowToolBar"
                                Width="{Binding Value, ElementName=WidthSlider}"
                                HorizontalAlignment="Left"
                                IsOverflowOpen="{Binding IsChecked, ElementName=IsOverflowOpenCheckBox}">
                                <Button Content="Item 1" />
                                <Button
                                    x:Name="OverflowTargetButton"
                                    Content="Target Item"
                                    ToolBar.OverflowMode="{Binding SelectedValue, ElementName=OverflowModeComboBox}" />
                                <Button Content="Item 2" />
                                <Button Content="Item 3" />
                                <Button Content="Item 4" />
                            </ToolBar>
                            <UniformGrid Margin="0,10,0,0" Columns="2">
                                <GroupBox Header="HasOverflowItems" Style="{StaticResource SubGroupBox}">
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding HasOverflowItems, ElementName=OverflowToolBar}" />
                                </GroupBox>
                                <GroupBox Header="IsOverflowItem" Style="{StaticResource SubGroupBox}">
                                    <TextBlock HorizontalAlignment="Center" Text="{Binding (ToolBar.IsOverflowItem), ElementName=OverflowTargetButton}" />
                                </GroupBox>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="OverflowDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=OverflowDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=OverflowDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="IsOverflowOpenCheckBox,OverflowModeComboBox,OverflowToolBar">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Band (ToolBar)&#10;BandIndex (ToolBar)" Style="{StaticResource ContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <ToolBarTray
                            x:Name="LayoutToolBarTray"
                            MinHeight="120"
                            Background="GhostWhite"
                            IsLocked="False">

                            <ToolBar
                                Background="LightYellow"
                                Band="0"
                                BandIndex="0">
                                <TextBlock
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="[Band:0, BandIndex:0]" />
                            </ToolBar>

                            <ToolBar
                                Background="LightBlue"
                                Band="0"
                                BandIndex="1">
                                <TextBlock
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="[Band:0, BandIndex:1]" />
                            </ToolBar>

                            <ToolBar
                                Background="LightGreen"
                                Band="1"
                                BandIndex="0">
                                <TextBlock
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="[Band:1, BandIndex:0]" />
                            </ToolBar>

                            <ToolBar
                                Background="Salmon"
                                Band="1"
                                BandIndex="1">
                                <TextBlock
                                    Margin="5"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Text="[Band:1, BandIndex:1]" />
                            </ToolBar>

                        </ToolBarTray>
                    </GroupBox>

                    <ToggleButton x:Name="LayoutDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=LayoutDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=LayoutDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="LayoutToolBarTray">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

            <Expander Header="Background (ToolBarTray)&#10;IsLocked (ToolBarTray)&#10;Orientation (ToolBarTray)&#10;Orientation (ToolBar)" Style="{StaticResource BaseContentsExpander}">
                <StackPanel>
                    <GroupBox Header="Property" Style="{StaticResource PropertyGroupBox}">
                        <UniformGrid Columns="3">
                            <GroupBox Header="Background" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="TrayBackgroundComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:StaticBindingSource TargetType=Brushes}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                            <GroupBox Header="IsLocked" Style="{StaticResource SubGroupBox}">
                                <CheckBox
                                    x:Name="IsLockedCheckBox"
                                    HorizontalAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Content="IsLocked" />
                            </GroupBox>
                            <GroupBox Header="Orientation(ToolBarTray)" Style="{StaticResource SubGroupBox}">
                                <ComboBox
                                    x:Name="TrayOrientationComboBox"
                                    DisplayMemberPath="Name"
                                    ItemsSource="{markupextensions:EnumBindingSource EnumType=Orientation}"
                                    SelectedIndex="0"
                                    SelectedValuePath="Value" />
                            </GroupBox>
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="Result" Style="{StaticResource ResultGroupBox}">
                        <StackPanel>
                            <ToolBarTray
                                x:Name="TrayPropertyToolBarTray"
                                Background="{Binding SelectedValue, ElementName=TrayBackgroundComboBox}"
                                IsLocked="{Binding IsChecked, ElementName=IsLockedCheckBox}"
                                Orientation="{Binding SelectedValue, ElementName=TrayOrientationComboBox}">
                                <ToolBar>
                                    <Button Content="New" />
                                    <Button Content="Open" />
                                </ToolBar>
                                <ToolBar x:Name="OrientationToolBar">
                                    <Button Content="Cut" />
                                    <Button Content="Copy" />
                                </ToolBar>
                            </ToolBarTray>
                            <GroupBox Header="Orientation(ToolBar)" Style="{StaticResource SubGroupBox}">
                                <TextBlock HorizontalAlignment="Center" Text="{Binding Orientation, ElementName=OrientationToolBar}" />
                            </GroupBox>
                        </StackPanel>
                    </GroupBox>
                    <ToggleButton x:Name="TrayPropertyDetailToggleButton" Style="{StaticResource HyperlinkToggleStyle}" />
                    <Popup
                        IsOpen="{Binding IsChecked, ElementName=TrayPropertyDetailToggleButton}"
                        PlacementTarget="{Binding ElementName=TrayPropertyDetailToggleButton}"
                        StaysOpen="False">
                        <Border Style="{StaticResource PopupBorderStyle}">
                            <Grid behaviors:XamlExtractBehavior.RawXamlFileName="{StaticResource rowXamlName}" behaviors:XamlExtractBehavior.TargetNames="TrayBackgroundComboBox,IsLockedCheckBox,TrayOrientationComboBox,TrayPropertyToolBarTray">
                                <TextBlock Style="{StaticResource CodeViewerHiddenTextBlockStyle}" />
                                <RichTextBox Style="{StaticResource CodeViewerRichTextBoxStyle}" />
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>
</UserControl>