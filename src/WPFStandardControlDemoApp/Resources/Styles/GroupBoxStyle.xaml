<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors">
    <Style x:Key="SubGroupBox" TargetType="{x:Type GroupBox}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBox
                        Margin="2,0"
                        behaviors:TextBoxSelectAllBehavior.IsEnabled="True"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="15"
                        IsReadOnly="True"
                        IsTabStop="False"
                        Text="{Binding Mode=OneWay}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="Black" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style x:Key="PropertyGroupBox" TargetType="{x:Type GroupBox}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBox
                        Margin="2,0"
                        behaviors:TextBoxSelectAllBehavior.IsEnabled="True"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=GroupBox, Mode=FindAncestor}}"
                        IsReadOnly="True"
                        IsTabStop="False"
                        Text="{Binding Mode=OneWay}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="RoyalBlue" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="4" />
    </Style>
    <Style x:Key="ResultGroupBox" TargetType="{x:Type GroupBox}">
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBox
                        Margin="2,0"
                        behaviors:TextBoxSelectAllBehavior.IsEnabled="True"
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=GroupBox, Mode=FindAncestor}}"
                        IsReadOnly="True"
                        IsTabStop="False"
                        Text="{Binding Mode=OneWay}" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="Tomato" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Padding" Value="4" />
    </Style>
</ResourceDictionary>