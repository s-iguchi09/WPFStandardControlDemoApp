<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:WPFStandardControlDemoApp.Common.Behaviors"
    xmlns:helpers="clr-namespace:WPFStandardControlDemoApp.Common.Helpers">
    <Style x:Key="CodeViewerRichTextBoxStyle" TargetType="RichTextBox">
        <Setter Property="Background" Value="White" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="behaviors:XamlColorizer.SourceText" Value="{Binding Path=(behaviors:XamlExtractBehavior.ExtractedXaml), RelativeSource={RelativeSource AncestorType=Grid}}" />
        <Setter Property="helpers:RichTextBoxHelper.BoundDocument" Value="{Binding Path=(behaviors:XamlColorizer.TargetDocument), RelativeSource={RelativeSource Self}}" />
        <Style.Resources>
            <Style TargetType="Paragraph">
                <Setter Property="Margin" Value="0" />
            </Style>
        </Style.Resources>
    </Style>

    <Style x:Key="CodeViewerHiddenTextBlockStyle" TargetType="TextBlock">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="Transparent" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Text" Value="{Binding Path=(behaviors:XamlExtractBehavior.ExtractedXaml), RelativeSource={RelativeSource AncestorType=Grid}}" />

    </Style>
</ResourceDictionary>